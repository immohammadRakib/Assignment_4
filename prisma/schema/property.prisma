model Property {
  id          String   @id @default(uuid())
  title       String
  description String
  location    String
  city        String
  pricePerDay Float
  images      String[]
  status      PropertyStatus @default(PENDING)
  views      Int        @default(0)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  landlordId  String
  landlord    User      @relation("LandlordProperties", fields: [landlordId], references: [id], onDelete: Cascade)
  
  // Clean relational categories constraint model mapping block

  bookings    Booking[]
  reviews     Review[]

  @@map("properties")
}



model Category {
  id         String     @id @default(uuid())
  name       String     @unique // e.g., Apartment, House, Studio
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Relation: Ekti category-r bhetor onek property thakte pare
 // properties Property[]

  @@map("categories")
}

